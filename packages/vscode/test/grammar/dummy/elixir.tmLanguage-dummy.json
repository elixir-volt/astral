{
  "name": "Dummy Elixir",
  "scopeName": "source.elixir",
  "patterns": [
    {
      "match": "\\b(assigns|assign|path|do|end|for)\\b",
      "name": "keyword.control.elixir"
    },
    {
      "match": ":[A-Za-z_][A-Za-z0-9_]*",
      "name": "constant.other.symbol.elixir"
    },
    {
      "match": "@[A-Za-z_][A-Za-z0-9_]*",
      "name": "variable.other.readwrite.module.elixir"
    }
  ]
}

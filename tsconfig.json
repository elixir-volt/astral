{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "astral:islands/runtime": ["./priv/islands/runtime.ts"],
      "astral:island-component": ["./priv/islands/virtual.d.ts"],
      "astral:island-runtime": ["./priv/islands/virtual.d.ts"]
    }
  },
  "include": ["priv/islands/**/*.ts", "priv/islands/**/*.d.ts"]
}
